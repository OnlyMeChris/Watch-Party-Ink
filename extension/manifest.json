{
  "manifest_version": 3,
  "name": "WatchInk Beta",
  "version": "1.0.0",
  "description": "Sync Disney+ playback with friends in real time. Watch together, perfectly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WatchInk Beta",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.disneyplus.com/*",
        "https://*.apps.disneyplus.com/*",
        "https://*.netflix.com/*",
        "https://netflix.com/*",
        "https://*.primevideo.com/*",
        "https://primevideo.com/*",
        "https://*.amazon.com/*",
        "https://amazon.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://*.youtu.be/*",
        "https://youtu.be/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.disneyplus.com/*",
    "https://*.apps.disneyplus.com/*",
    "https://*.netflix.com/*",
    "https://netflix.com/*",
    "https://*.primevideo.com/*",
    "https://primevideo.com/*",
    "https://*.amazon.com/*",
    "https://amazon.com/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://*.youtu.be/*",
    "https://youtu.be/*",
    "https://watchink-server.onrender.com/*",
    "wss://watchink-server.onrender.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles.css"],
      "matches": [
        "https://*.disneyplus.com/*",
        "https://*.apps.disneyplus.com/*",
        "https://*.netflix.com/*",
        "https://netflix.com/*",
        "https://*.primevideo.com/*",
        "https://primevideo.com/*",
        "https://*.amazon.com/*",
        "https://amazon.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://*.youtu.be/*",
        "https://youtu.be/*"
      ]
    }
  ]
}
